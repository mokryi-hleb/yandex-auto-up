# Required: ID of the VM, e.g. fhm1234567890abcdef
YC_INSTANCE_ID=

# Use one authentication option. A service-account authorized-key file is
# recommended for a watchdog running outside Yandex Cloud.
YC_SERVICE_ACCOUNT_KEY_FILE=
# Metadata token is for a watchdog on another Yandex Cloud VM with an attached
# service account.
YC_USE_METADATA_TOKEN=false
# IAM token has priority if several options are set; it expires within 12 hours.
YC_IAM_TOKEN=
# Legacy option: Yandex Cloud no longer accepts new OAuth tokens from Yandex ID.
# YC_OAUTH_TOKEN=

# Optional
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=15
LOG_LEVEL=INFO
