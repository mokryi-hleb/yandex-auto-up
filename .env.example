# Required: ID of the VM, e.g. fhm1234567890abcdef
YC_INSTANCE_ID=

# Use one authentication option. Metadata token is recommended for a watchdog
# running on another Yandex Cloud VM with an attached service account.
YC_USE_METADATA_TOKEN=false
# IAM token has priority if several options are set; it expires within 12 hours.
YC_IAM_TOKEN=
# Legacy option: Yandex Cloud no longer accepts new OAuth tokens from Yandex ID.
# YC_OAUTH_TOKEN=

# Optional
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=15
LOG_LEVEL=INFO
